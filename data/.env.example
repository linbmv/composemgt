# ====================== 全局网络与主机配置 ======================
# Tailscale 主机 IP 或者是宿主机 IP（用于端口绑定绑定特定的网卡）
TS_HOST_IP=100.101.102.100

# Docker 自定义网段前缀（例如：172.18.0，容器 IP 将为 172.18.0.xxx）
SUBNET_PREFIX=172.18.0

# 默认时区
TZ=Asia/Shanghai

# 默认日志级别
LOG_LEVEL=INFO

# ====================== 1. Cloudflare Tunnel ======================
# Cloudflare Tunnel 访问令牌
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiMjM3MWI1ZDQ2OTlhMGY5YzVkMTczYWI4ZjFjY2Y2NmIiLCJ0IjoiNGYxNzE0OWQtNzcwNi00NTk4LTk2ZWUtZjdmYmJkMjA0ZTEzIiwicyI6IlpHUmxZMkUyWTJFdE5Ea3hZaTAwTUdSbUxXRXlaak10WlRFME1qbGxNMll3WkdObCJ9

# ====================== 2. Postgres 数据库 ======================
# 数据库超级管理员密码
